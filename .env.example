# Supabase — set in `.env.local` (local) and Vercel → Project → Environment Variables (prod).
# When unset, the app uses demo admin credentials for local development.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Either the legacy anon JWT key…
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# …or the newer publishable key (sb_publishable_…) — both work.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_…
