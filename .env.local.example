# Grids Gold — environment variables
#
# Copy this file to `.env.local` (which is git-ignored) and fill in the real
# values from your Supabase project (Settings → API). Do NOT commit real keys.
#
# For Vercel: add these same two variables under
# Project → Settings → Environment Variables, then redeploy.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY
